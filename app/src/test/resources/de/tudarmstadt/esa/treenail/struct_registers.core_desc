InstructionSet StructRegisters {
  architectural_state {
    struct UVec2 {
      unsigned<32> x, y;
    }
    struct VecAndInt {
      signed<32> notNested;
      struct UVec2 vec;
    }
    register struct UVec2 STRUCT_REG;
    register struct VecAndInt NESTED_STRUCT_REG;
  }

  instructions {
    StructRegDirectStore {
      encoding: imm[11:0] :: rs1[4:0] :: 3'b010 :: rd[4:0] :: 7'b0000011;
      behavior: {
        struct UVec2 localStruct = STRUCT_REG;
        localStruct.x = rs1;
        STRUCT_REG = localStruct;
        STRUCT_REG.x -= 1;
        NESTED_STRUCT_REG.vec.x = 7;
      }
    }
  }
}