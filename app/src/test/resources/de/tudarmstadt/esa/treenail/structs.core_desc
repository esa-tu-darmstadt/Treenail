InstructionSet Structs {
  architectural_state {
    struct Simple {
      unsigned<32> x, y;
      signed<16> a, b, c, d;
    }
    struct Nested {
      unsigned<32> notNested;
      struct Simple nested;
    }
  }

  instructions {
    StructTest {
      encoding: imm[11:0] :: rs1[4:0] :: 3'b010 :: rd[4:0] :: 7'b0000011;
      behavior: {
        struct Simple localStruct;
        localStruct.x = 10;
        localStruct.c = -1;
        localStruct.x -= rs1;
        struct Nested nested;
        nested.nested = localStruct;
      }
    }
  }
}
