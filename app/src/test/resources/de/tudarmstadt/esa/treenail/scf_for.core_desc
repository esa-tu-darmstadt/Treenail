InstructionSet TestScfForLoop {
    architectural_state {
      unsigned int XLEN = 32;
      unsigned int RFS = 32;
      register unsigned<XLEN> X[RFS] [[is_main_reg]];
      extern unsigned<8> MEM[1 << XLEN] [[is_main_mem]];
      register unsigned<XLEN> TEST_REG = 10;
      unsigned<XLEN> &REG_REF = TEST_REG;
      unsigned<XLEN> &REG_REF_REF = REG_REF;
    }

  instructions {
    ConstBoundsLT {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = 0; i < 20; ++i) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    ConstBoundsLE {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = 0; i <= 20; i++) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    ConstBoundsStep2 {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = 0; i < 20; i += 2) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    ConstBoundsGT {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (signed<32> i = 1; i > -20; i -= 2) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    ConstBoundsGE {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (signed<32> i = 1; i >= -20; i -= 2) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeInitBound {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < y; ++i) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeInitBoundStep {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> step = X[rs1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < y; i += step) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedNotViableIteratorModified {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < y; ++i) {
          if (MEM[rs1 + i] == 123) {
            i += 10; // iterator modified -> can't use scf.for
          }
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedNotViableBoundModified {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < y; ++i) {
          if (MEM[rs1 + i] == 123) {
            y += 10; // bound modified -> can't use scf.for
          }
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedViableRef {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < REG_REF; ++i) {
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedNotViableModifiedBoundPointee {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < REG_REF; ++i) {
          if (MEM[rs1 + i] == 123) {
            TEST_REG += 2; // modifies REG_REF
          }
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedNotViableModifiedBoundPointer {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < TEST_REG; ++i) {
          if (MEM[rs1 + i] == 123) {
            REG_REF += 2;
          }
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
    RuntimeBoundedNotViableModifiedBoundMultipleRef {
      encoding: 5'b00000 :: 1'b0 :: Imm6[0:5] :: rs1[4:3] :: rs1[0:2] :: 3'b110 :: rd[4:0] :: 7'b1111011;
      behavior: {
        unsigned<32> x = MEM[Imm6];
        unsigned<32> y = MEM[Imm6 + 1];
        unsigned<32> sum = 0;
        for (unsigned<32> i = x; i < REG_REF; ++i) {
          if (MEM[rs1 + i] == 123) {
            REG_REF_REF += 2;
          }
          sum += MEM[rs1 + i];
        }
        MEM[Imm6:Imm6 + 3] = sum;
      }
    }
  }
}
